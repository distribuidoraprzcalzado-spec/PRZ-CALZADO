{
  "enabled": true,
  "name": "Auto Deploy a GitHub",
  "description": "Hace git add, commit y push automáticamente cada vez que Kiro termina de hacer cambios, para que Netlify despliegue el sitio actualizado.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "cd \"C:\\Users\\Juan Carlos\\prz-calzado\" && git add . && git diff --cached --quiet || git commit -m \"Auto-deploy: cambios desde Kiro\" && git push origin master"
  }
}